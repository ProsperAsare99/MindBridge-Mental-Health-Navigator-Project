generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  output          = "../src/generated/client_new"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// CORE USER MODELS
// ============================================

model User {
  id                    String    @id @default(uuid())
  googleId              String?   @unique
  email                 String    @unique
  password              String?
  displayName           String
  avatar                String?
  role                  String    @default("user")
  institution           String?
  department            String?
  yearOfStudy           Int?
  
  // Wellness Profile
  onboarded             Boolean   @default(false)
  
  // Social
  circles               CircleMember[]
  posts                 Post[]
  encouragements        Encouragement[]
  
  // Health Data
  moods                 Mood[]
  assessments           Assessment[]
  goals                 UserGoal[]
  medications           Medication[]
  
  // Gamification
  points                Int       @default(0)
  level                 Int       @default(1)
  badges                UserBadge[]
  streak                Int       @default(0)
  lastMoodLog           DateTime?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Mood {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  score           Int         // 1-10 scale
  emotion         String      // Main emotion from wheel
  intensity       Int         // 1-100%
  
  notes           String?     @db.Text
  activities      String[]    // Tagged activities
  
  // Media Attachments
  photoUrl        String?
  audioUrl        String?
  transcription   String?     @db.Text
  
  // Context
  sleepHours      Float?
  productivity    Int?        // 1-10
  stressLevel     Int?        // 1-10
  
  // AI Insights
  sentimentScore  Float?      // -1.0 to 1.0
  crisisFlag      Boolean     @default(false)
  aiSummary       String?     @db.Text
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Assessment {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type            AssessmentType
  score           Int
  severity        Severity
  responses       Json
  
  createdAt       DateTime    @default(now())
}

model Circle {
  id              String      @id @default(uuid())
  name            String      @unique
  description     String
  category        String      // Academic, Mental Health, Social, etc.
  icon            String?
  
  members         CircleMember[]
  posts           Post[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model CircleMember {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  circleId        String
  circle          Circle      @relation(fields: [circleId], references: [id], onDelete: Cascade)
  role            String    @default("member")
  
  joinedAt        DateTime  @default(now())

  @@unique([userId, circleId])
}

model Post {
  id              String      @id @default(uuid())
  content         String      @db.Text
  isAnonymous     Boolean     @default(true)
  
  circleId        String
  circle          Circle      @relation(fields: [circleId], references: [id], onDelete: Cascade)
  authorId        String
  author          User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  encouragements  Encouragement[]
  
  // Safety
  crisisFlag      Boolean     @default(false)
  moderationStatus String     @default("pending") // pending, approved, flagged
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Encouragement {
  id              String    @id @default(uuid())
  postId          String
  post            Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime  @default(now())

  @@unique([postId, userId])
}

model UserGoal {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title           String
  description     String?
  category        String
  status          GoalStatus  @default(ACTIVE)
  
  currentValue    Float       @default(0)
  targetValue     Float
  unit            String?
  
  deadline        DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Badge {
  id              String      @id @default(uuid())
  name            String      @unique
  description     String
  icon            String
  points          Int         @default(50)
  
  users           UserBadge[]
}

model UserBadge {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId         String
  badge           Badge     @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  
  unlockedAt      DateTime  @default(now())

  @@unique([userId, badgeId])
}

model Medication {
  id                String      @id @default(uuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name              String
  dosage            String
  frequency         String
  reminders         Boolean     @default(true)
  schedule          Json?       // {"time": "08:00", "days": ["mon", "wed"]}
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

// ============================================
// ENUMS
// ============================================

enum TimeOfDay {
  MORNING
  AFTERNOON
  EVENING
  NIGHT
}

enum Concern {
  ACADEMIC_STRESS
  ANXIETY
  DEPRESSION
  LONELINESS
  RELATIONSHIP_ISSUES
  FINANCIAL_STRESS
  FAMILY_PRESSURE
  OTHER
}

enum SupportLevel {
  ALONE
  SOMEWHAT
  STRONG
}

enum RiskLevel {
  LOW
  MODERATE
  HIGH
  CRITICAL
}

enum CopingStyle {
  EXERCISE
  JOURNAL
  PRAY
  TALK
  MUSIC
  SLEEP
  MEDITATE
  OTHER
}

enum FaithLevel {
  VERY_IMPORTANT
  SOMEWHAT_IMPORTANT
  NOT_IMPORTANT
}

enum ApproachPreference {
  CLINICAL
  HOLISTIC
  CULTURAL
  MIXED
}

enum Goal {
  REDUCE_STRESS
  IMPROVE_MOOD
  BUILD_RESILIENCE
  BETTER_SLEEP
  DEVELOP_HABITS
  CONNECT_SUPPORT
  TRACK_JOURNEY
  PREPARE_COUNSELING
  BE_MINDFUL
  IMPROVE_ACADEMICS
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ConversationStatus {
  ACTIVE
  ENDED
  ARCHIVED
}

enum MessageRole {
  USER
  ASSISTANT
}

enum AssessmentType {
  PHQ9
  GAD7
  PSS
  CUSTOM
}

enum Severity {
  MINIMAL
  MILD
  MODERATE
  MODERATELY_SEVERE
  SEVERE
}

enum Service {
  GEMINI
  CHAT
  MOOD
  ASSESSMENT
}